{
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest --run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "dev:client": "npm run dev -w @onlycards/client",
    "dev:admin": "npm run dev -w @onlycards/admin",
    "dev:landing": "npm run dev -w @onlycards/landing",
    "build:ui": "npm run build -w @onlycards/ui",
    "build:service": "npm run build -w @onlycards/service",
    "build:client": "npm run build -w @onlycards/client",
    "build:admin": "npm run build -w @onlycards/admin",
    "build:landing": "npm run build -w @onlycards/landing",
    "build": "npm run build:service && npm run build:ui && npm run build:client && npm run build:admin && npm run build:landing",
    "ts": "npm run ts -w @onlycards/service && npm run ts -w @onlycards/ui && npm run ts -w @onlycards/client && npm run ts -w @onlycards/admin && npm run ts -w @onlycards/landing"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.8",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.1.3"
  }
}
